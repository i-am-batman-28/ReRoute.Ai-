# ReRoute.AI — copy to one of:
#   • ReRoute.Ai-/.env                    (repo root, shared)
#   • reroute-ai/.env                     (project folder)
#   • reroute-ai/backend/.env             (backend-only)
# Backend loads all existing files in that order; later files override earlier ones.

# --- Database ---
# 1) Postgres: `docker compose -f reroute-ai/docker-compose.yml up -d`
DATABASE_URL=postgresql+asyncpg://reroute:reroute_dev@localhost:5433/reroute
# Quick local file DB (relative to process cwd when using SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./reroute.db

# --- Auth ---
JWT_SECRET_KEY=change-me-use-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- HTTP API ---
API_PREFIX=/api
# Comma-separated browser origins for CORS (include your Next.js dev URL)
CORS_ORIGINS=http://localhost:3000

# --- Optional: SQL echo ---
# DEBUG_SQL=true

# --- Optional: flights (integrations/flight_status.py) ---
# AVIATION_STACK_API_KEY=

# --- Optional: weather (Open-Meteo is default; flag toggles usage paths) ---
# OPEN_METEO_ENABLED=true

# --- Optional: multi-modal routing (integrations/maps_routes.py) ---
# OPENROUTESERVICE_API_KEY=

# Redis + Celery (`docker compose -f reroute-ai/docker-compose.yml up -d redis`)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Agent: queue Resend emails in worker (requires Celery worker)
# EMAIL_VIA_CELERY=false

# Outbound HTTP timeouts (seconds)
# HTTP_TIMEOUT_CONNECT=10
# HTTP_TIMEOUT_READ=90

# Stale `applying` proposal reset (Celery beat every 5m uses this)
# STALE_APPLYING_MINUTES=15

# Migrations (from reroute-ai/backend): `alembic upgrade head`

# --- Optional: Duffel NDC (integrations/duffel_client.py) ---
# DUFFEL_API_KEY=
# DUFFEL_VERSION=v2

# --- Optional: outbound email (integrations/resend_client.py) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@reroute.ai
# EMAIL_ENABLED=true

# --- Optional: LangChain / OpenAI when agent extras are installed ---
# OPENAI_API_KEY=

# --- Frontend (copy to reroute-ai/frontend/.env.local; not read by backend) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000

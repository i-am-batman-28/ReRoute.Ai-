# Backend — prefer repo-root `.env` (see repository root `.env.example`). Config loads workspace root `.env`.
# CORS_ORIGINS=http://localhost:3000
# API_PREFIX=/api
# DATABASE_URL=postgresql+asyncpg://reroute:reroute_dev@localhost:5433/reroute
# DATABASE_URL=sqlite+aiosqlite:///./reroute.db
# JWT_SECRET_KEY=your-long-random-secret
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend (copy to frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Agent (backend optional extras)
# OPENAI_API_KEY=
